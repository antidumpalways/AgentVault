# ============================================================
# AgentVault — environment template
# Copy to `.env.local` for local dev, or set in Vercel dashboard
# ============================================================

# Story Protocol RPC + Indexer (Aeneid testnet)
RPC_URL=https://aeneid.storyrpc.io
STORY_API_URL=https://aeneid.storyapi.dev

# Server-side signer — used to send CDR + Story transactions.
# MUST be funded with IP on Aeneid. Never commit this key.
WALLET_PRIVATE_KEY=0x

# Anthropic LLM (Claude). Without this, /api/llm/chat falls back to canned replies.
LLM_API_KEY=sk-ant-
LLM_API_URL=https://api.anthropic.com/v1/messages
LLM_MODEL=claude-sonnet-4-20250514

# CSRF allow-list. Set NEXT_PUBLIC_SITE_URL to the deployed origin so
# cross-origin POSTs are accepted. On Vercel, VERCEL_URL is auto-populated.
NEXT_PUBLIC_SITE_URL=https://agentvault.vercel.app
